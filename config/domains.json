{
  "domains": [
    {
      "id": "security",
      "name": "Security",
      "order": 1,
      "lenses": ["injection", "xss-csrf", "auth-session", "authorization", "secrets", "dependency-cves", "security-headers", "cryptography", "input-sanitization", "data-exposure", "rate-abuse"]
    },
    {
      "id": "code-quality",
      "name": "Code Quality",
      "order": 2,
      "lenses": ["naming", "complexity", "dead-code", "duplication", "magic-values", "code-smells", "linting", "formatting", "comments", "type-safety", "immutability", "readability", "consistency", "pattern-consistency"]
    },
    {
      "id": "architecture",
      "name": "Architecture",
      "order": 3,
      "lenses": ["separation-of-concerns", "module-boundaries", "circular-deps", "coupling", "single-responsibility", "dependency-direction", "api-contract", "state-architecture", "extensibility"]
    },
    {
      "id": "testing",
      "name": "Testing",
      "order": 4,
      "lenses": ["unit-test-gaps", "integration-test-gaps", "e2e-test-gaps", "test-quality", "test-anti-patterns", "edge-cases", "error-path-tests", "test-maintainability", "test-determinism"]
    },
    {
      "id": "error-handling",
      "name": "Error Handling",
      "order": 5,
      "lenses": ["unhandled-errors", "error-swallowing", "error-messages", "error-boundaries", "graceful-degradation", "timeout-retry"]
