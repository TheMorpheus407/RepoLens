      "name": "API Design",
      "order": 7,
      "lenses": ["rest-conventions", "request-validation", "response-consistency", "api-versioning", "api-idempotency", "api-documentation"]
    },
    {
      "id": "database",
      "name": "Database",
      "order": 8,
      "lenses": ["schema-design", "migration-quality", "index-strategy", "transaction-safety", "data-integrity", "query-safety"]
    },
    {
      "id": "frontend",
      "name": "Frontend",
      "order": 9,
      "lenses": ["component-architecture", "accessibility", "responsive-design", "loading-states", "error-states", "empty-states", "form-ux", "routing", "frontend-security"]
    },
    {
